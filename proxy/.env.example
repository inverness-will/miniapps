# Copy to .env and fill in. Never commit .env.
ALTA_HOST=https://your-alta-server.example.com
ALTA_USERNAME=your_username
ALTA_PASSWORD=your_password

# Optional: override default watchlist name (case-insensitive match)
# WATCHLIST_NAME=patients

# Optional: bind address for local dev
# PROXY_HOST=127.0.0.1
# PROXY_PORT=8765
