# Copy to .env and fill in. Never commit .env.
# EU / cloud example:
# ALTA_HOST=https://will.eu2.alta.avigilon.com
#
# Use the same email and password you use in the Alta web UI (often full email as username).
# Avoid trailing spaces after values — they cause 401 Unauthorized.
ALTA_HOST=https://your-alta-server.example.com
ALTA_USERNAME=your_username_or_email
ALTA_PASSWORD=your_password

# Optional: only if your Alta build uses a non-default login path (Avigilon Alta uses dologin)
# ALTA_LOGIN_PATH=/api/v1/dologin
# ALTA_LOGIN_PATH=dologin

# Optional: override User-Agent sent to Alta (defaults to a browser-like string)
# ALTA_USER_AGENT=Mozilla/5.0 ...

# Optional: verbose login debugging to stderr (host, env vs effective username, etc.)
# ALTA_DEBUG=1
#
# Optional: also log password repr from env and JSON body (security risk — remove after debugging)
# ALTA_DEBUG_LOG_PASSWORD=1

# Optional: override default watchlist name (case-insensitive match)
# WATCHLIST_NAME=patients

# Optional: bind address for local dev (0.0.0.0 = accept Chrome on http://YOUR-HOSTNAME:8080 → API :8765)
# PROXY_HOST=127.0.0.1
# PROXY_HOST=0.0.0.0
# PROXY_PORT=8765
